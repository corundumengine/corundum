PROJECT_NAME           = "Corundum Engine"
PROJECT_NUMBER         = @PROJECT_VERSION@
PROJECT_BRIEF          = "Public engine API reference"
OUTPUT_DIRECTORY       = @CMAKE_BINARY_DIR@/docs

INPUT                  = @CMAKE_SOURCE_DIR@/engine/include/corundum
RECURSIVE              = YES
FILE_PATTERNS          = *.hpp

USE_MDFILE_AS_MAINPAGE = @CMAKE_SOURCE_DIR@/README.md
INPUT                  += @CMAKE_SOURCE_DIR@/README.md

EXTRACT_ALL             = NO
EXTRACT_PRIVATE         = NO
EXTRACT_STATIC          = NO
HIDE_UNDOC_MEMBERS      = NO
HIDE_UNDOC_CLASSES      = NO

WARN_IF_UNDOCUMENTED   = YES
WARN_AS_ERROR          = NO
QUIET                  = NO

GENERATE_HTML          = YES
GENERATE_LATEX         = NO
GENERATE_MAN           = NO
GENERATE_RTF           = NO

GENERATE_TREEVIEW      = YES
DISABLE_INDEX          = NO
FULL_SIDEBAR           = NO
HTML_COLORSTYLE        = LIGHT
HTML_EXTRA_STYLESHEET  = @doxygen_awesome_css_SOURCE_DIR@/doxygen-awesome.css \
                         @doxygen_awesome_css_SOURCE_DIR@/doxygen-awesome-sidebar-only.css \
                         @CMAKE_SOURCE_DIR@/cmake/doxygen-custom.css

JAVADOC_AUTOBRIEF       = NO
OPTIMIZE_OUTPUT_FOR_C   = NO
BUILTIN_STL_SUPPORT     = YES

HAVE_DOT                = NO
